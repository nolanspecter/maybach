# Provider selection: bedrock | ollama
# Default is bedrock. Set to ollama to run fully free with a local model.
LLM_PROVIDER=ollama

# ── Ollama (free, local) ─────────────────────────────────────────────────────
# Install: https://ollama.com  then run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── AWS Bedrock (paid) ───────────────────────────────────────────────────────
# Uncomment and fill in when switching to LLM_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_DEFAULT_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250514-v1:0
