# Provider: bedrock (default) | ollama
# Bedrock uses the standard AWS credential chain: it auto-detects a SageMaker/
# EC2/ECS execution role, an ~/.aws profile, or the keys below. With no creds
# at all it auto-falls back to Ollama. On SageMaker leave the keys blank — the
# execution role is picked up automatically.
LLM_PROVIDER=bedrock

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Optional — only needed when NOT running with an execution role/profile.
# Use permanent IAM user keys (start with AKIA) — not temporary session keys (ASIA)
# IAM → Users → Security credentials → Create access key → "Outside AWS"
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250514-v1:0

# Only needed if using temporary session credentials (ASIA keys) — not recommended
# AWS_SESSION_TOKEN=your_session_token_here

# ── Ollama (fallback / free local) ───────────────────────────────────────────
# Install: https://ollama.com  then: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
 