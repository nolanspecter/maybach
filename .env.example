# Maybach runs entirely on a local Ollama server — no API keys needed.
# These are optional overrides; the defaults shown are used otherwise.
#
# Install Ollama: https://ollama.com
# Pull a tool-capable model:  ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# The router only classifies requests — a small model is plenty.
# Defaults to OLLAMA_MODEL if unset.
# OLLAMA_ROUTER_MODEL=llama3.2

# Where agents read/write shared files (default: ./workspace)
# WORKSPACE_DIR=workspace
