# Copy to config.yaml and adjust. All settings are optional — the defaults
# below are used if config.yaml is absent.
ollama:
  # Install: https://ollama.com  then pull a tool-capable model:
  #   ollama pull llama3.2
  model: llama3.2
  base_url: http://localhost:11434

  # Optional — the router only classifies the request, so a small model is fine.
  # Defaults to `model` above if omitted.
  # router_model: llama3.2
