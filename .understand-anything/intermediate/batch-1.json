    {
      "id": "file:orchestrator.py",
      "type": "file",
      "name": "orchestrator.py",
      "filePath": "orchestrator.py",
      "summary": "Core LangGraph supervisor orchestrating the four virtual employee agents. Uses an LLM-powered router to fan out tasks in parallel via the Send API, collect results through an aggregator, and loop back until work is complete.",
      "tags": ["orchestration", "langgraph", "supervisor", "multi-agent"],
      "complexity": "complex",
      "languageNotes": "Employs LangGraph's Send API for dynamic parallel fan-out to worker nodes, with the aggregator acting as a synchronization barrier before looping back to the router."
    },
